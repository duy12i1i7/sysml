          <geometry>
            <mesh>
              <uri>file:///opt/ros/jazzy/share/turtlebot4_description/meshes/shell.dae</uri>
            </mesh>
          </geometry>
        </visual>
        <visual name="tower_front_left_visual">
          <pose>0.0306 0.1143 0.2418 0 1.5708 0</pose>
          <geometry>
            <mesh>
              <uri>file:///opt/ros/jazzy/share/turtlebot4_description/meshes/tower_standoff.dae</uri>
            </mesh>
          </geometry>
        </visual>
        <visual name="tower_front_right_visual">
          <pose>0.0306 -0.1143 0.2418 0 1.5708 0</pose>
          <geometry>
            <mesh>
              <uri>file:///opt/ros/jazzy/share/turtlebot4_description/meshes/tower_standoff.dae</uri>
            </mesh>
          </geometry>
        </visual>
        <visual name="tower_rear_left_visual">
          <pose>-0.0761 0.0907 0.2418 0 1.5708 0</pose>
          <geometry>
            <mesh>
              <uri>file:///opt/ros/jazzy/share/turtlebot4_description/meshes/tower_standoff.dae</uri>
            </mesh>
          </geometry>
        </visual>
        <visual name="tower_rear_right_visual">
          <pose>-0.0761 -0.0907 0.2418 0 1.5708 0</pose>
          <geometry>
            <mesh>
              <uri>file:///opt/ros/jazzy/share/turtlebot4_description/meshes/tower_standoff.dae</uri>
            </mesh>
          </geometry>
        </visual>
        <visual name="tower_sensor_plate_visual">
          <pose>0 0 0.3468 0 0 0</pose>
          <geometry>
            <mesh>
              <uri>file:///opt/ros/jazzy/share/turtlebot4_description/meshes/tower_sensor_plate.dae</uri>
            </mesh>
          </geometry>
        </visual>
        <visual name="rplidar_visual">
          <pose>-0.04 0 0.1929 0 0 1.5708</pose>
          <geometry>
            <mesh>
              <uri>file:///opt/ros/jazzy/share/turtlebot4_description/meshes/rplidar.dae</uri>
            </mesh>
          </geometry>
        </visual>
        <visual name="oakd_camera_bracket_visual">
          <pose>-0.118 0 0.1468 0 0 0</pose>
          <geometry>
            <mesh>
              <uri>file:///opt/ros/jazzy/share/turtlebot4_description/meshes/camera_bracket.dae</uri>
            </mesh>
          </geometry>
        </visual>
        <visual name="oakd_pro_visual">
          <pose>-0.0596 0 0.2435 0 0 0</pose>
          <geometry>
            <mesh>
              <uri>file:///opt/ros/jazzy/share/turtlebot4_description/meshes/oakd_pro.dae</uri>
            </mesh>
          </geometry>
        </visual>
      </link>
      <link name="left_wheel">
        <pose>0 0.16 -0.035 -1.5707 0 0</pose>
        <inertial>
          <mass>0.08</mass>
          <inertia>
            <ixx>0.00003</ixx>
            <iyy>0.00003</iyy>
            <izz>0.00005</izz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.04</radius>
              <length>0.035</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.04</radius>
              <length>0.035</length>
            </cylinder>
          </geometry>
        </visual>
      </link>
      <link name="right_wheel">
        <pose>0 -0.16 -0.035 -1.5707 0 0</pose>
        <inertial>
          <mass>0.08</mass>
          <inertia>
            <ixx>0.00003</ixx>
            <iyy>0.00003</iyy>
            <izz>0.00005</izz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.04</radius>
              <length>0.035</length>
            </cylinder>
