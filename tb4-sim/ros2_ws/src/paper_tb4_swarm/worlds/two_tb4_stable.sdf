<?xml version="1.0"?>
<sdf version="1.9">
  <world name="two_tb4_stable">
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>

    <physics name="stable_step" type="ignored">
      <max_step_size>0.005</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <scene>
      <ambient>0.4 0.4 0.4 1</ambient>
      <background>0.8 0.85 0.9 1</background>
      <shadows>false</shadows>
    </scene>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>10 10</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>10 10</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.78 0.78 0.76 1</ambient>
            <diffuse>0.78 0.78 0.76 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="target_marker">
      <static>true</static>
      <pose>1.5 0 0.02 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.12</radius>
              <length>0.04</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>1.0 0.1 0.1 1</ambient>
            <diffuse>1.0 0.1 0.1 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="robot1">
      <pose>0 0 0.08 0 0 0</pose>
      <link name="base_link">
        <inertial>
          <mass>2.5</mass>
          <inertia>
            <ixx>0.04</ixx>
            <iyy>0.04</iyy>
            <izz>0.06</izz>
          </inertia>
        </inertial>
        <collision name="base_collision">
          <geometry>
            <box>
              <size>0.34 0.28 0.12</size>
            </box>
          </geometry>
        </collision>
        <visual name="create3_body_visual">
          <pose>0 0 0.0392 0 0 1.5708</pose>
          <geometry>
            <mesh>
              <uri>file:///opt/ros/jazzy/share/irobot_create_description/meshes/body_visual.dae</uri>
            </mesh>
          </geometry>
        </visual>
        <visual name="create3_bumper_visual">
          <pose>0 0 0.0392 0 0 0</pose>
          <geometry>
            <mesh>
