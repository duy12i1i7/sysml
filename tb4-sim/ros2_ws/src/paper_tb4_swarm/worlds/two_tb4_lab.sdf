          <geometry>
            <cylinder>
              <radius>0.04</radius>
              <length>0.035</length>
            </cylinder>
          </geometry>
        </visual>
      </link>
      <link name="right_wheel">
        <pose>0 -0.16 -0.035 -1.5707 0 0</pose>
        <inertial>
          <mass>0.08</mass>
          <inertia>
            <ixx>0.00003</ixx>
            <iyy>0.00003</iyy>
            <izz>0.00005</izz>
          </inertia>
